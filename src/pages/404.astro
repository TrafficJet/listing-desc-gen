---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | ListingDescGen" description="The page you're looking for doesn't exist.">
  <div class="text-center py-24">
    <h1 class="text-6xl font-bold text-violet-700 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">This page doesn't exist.</p>
    <a href="/" class="inline-block bg-violet-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-violet-800 transition">
      Back to Generator
    </a>
    <div class="mt-10 flex gap-4 justify-center text-sm">
      <a href="/examples/" class="text-violet-600 hover:underline">Examples</a>
      <a href="/tips/" class="text-violet-600 hover:underline">Tips</a>
      <a href="/about/" class="text-violet-600 hover:underline">About</a>
    </div>
  </div>
</Base>
