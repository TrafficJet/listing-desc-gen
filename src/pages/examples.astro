---
import Base from '../layouts/Base.astro';

const examples = [
  {
    label: "3BR Single Family — Austin, TX",
    desc: `Welcome to this beautifully updated 3-bedroom, 2-bathroom home in the heart of South Austin. Built in 2005 and thoughtfully renovated in 2023, this 1,850 sq ft property features an open floor plan, hardwood floors throughout, and a chef's kitchen with quartz countertops and stainless appliances. The primary suite boasts a walk-in closet and spa-style bath. Step outside to a large backyard deck perfect for entertaining. Located minutes from top-rated schools, Barton Springs, and South Congress dining. This move-in-ready gem won't last — schedule your showing today.`
  },
  {
    label: "2BR Condo — Downtown Chicago, IL",
    desc: `Stunning 2-bed, 2-bath corner unit on the 18th floor with panoramic city and lake views. This 1,200 sq ft residence offers floor-to-ceiling windows, designer finishes, and an in-unit washer/dryer. The gourmet kitchen features Italian cabinetry and Bosch appliances. Building amenities include 24-hr doorman, rooftop deck, fitness center, and heated garage parking. Steps to Millennium Park, the Riverwalk, and the Blue Line. Ideal for professionals or as a luxury pied-à-terre. Priced to move — serious inquiries only.`
  },
  {
    label: "4BR Investment Property — Phoenix, AZ",
    desc: `Exceptional investment opportunity: a fully rented 4-bed, 2-bath single-family home generating $2,400/month in stable rental income. Built in 1998, this 1,680 sq ft property features a new roof (2022), updated HVAC (2021), and a 2-car garage. Current tenants are month-to-month. Located in a high-demand rental corridor near Loop 101, shopping centers, and Scottsdale Community College. Cap rate of approximately 6.2% at asking price. Ideal for buy-and-hold investors seeking immediate cash flow with minimal deferred maintenance.`
  },
  {
    label: "5BR Luxury Home — Naples, FL",
    desc: `An exceptional estate in Pelican Bay offering 5 bedrooms, 5.5 bathrooms, and 5,200 sq ft of refined living space. Soaring coffered ceilings, wide-plank white oak floors, and a grand foyer set the tone for this architecturally distinguished residence. The chef's kitchen opens to a great room with disappearing glass doors leading to the resort-style lanai, salt-water pool, and outdoor kitchen. The primary suite is a private retreat with a morning bar, dual closets, and a spa bath. Three-car garage, whole-home generator, and smart-home automation throughout. Steps to Pelican Bay's private beach clubs. Offered at $4,750,000.`
  },
];
---
<Base
  title="Real Estate Listing Description Examples"
  description="See example real estate listing descriptions for single family homes, condos, investment properties, and luxury estates."
>
  <h1 class="text-3xl font-bold mb-2">Listing Description Examples</h1>
  <p class="text-gray-500 mb-8">Real examples of professional listing descriptions across different property types.</p>
  <div class="space-y-8">
    {examples.map(ex => (
      <div class="border rounded-xl p-6 bg-gray-50">
        <p class="text-sm font-semibold text-violet-700 mb-2">{ex.label}</p>
        <p class="text-gray-700 leading-relaxed">{ex.desc}</p>
      </div>
    ))}
  </div>
  <div class="mt-10 text-center">
    <a href="/" class="inline-block bg-violet-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-violet-800 transition">Generate Your Own →</a>
  </div>
</Base>
